# ============================================
# Muhasib.ai Environment Configuration
# ============================================
# Copy this file to .env and fill in the values.
# Validation lives in server/config/env.ts — see that file for the source of truth.

# === Required ===
DATABASE_URL=postgresql://user:password@host:5432/muhasib_db
SESSION_SECRET=your-session-secret-at-least-32-characters-long
JWT_SECRET=your-jwt-secret-at-least-32-characters-long-different-from-session

# === Server ===
NODE_ENV=development
PORT=5000
# bcrypt password-hash work factor. Optional; defaults to 12. Hard floor of 12
# (OWASP), capped at 15. Existing lower-cost hashes keep working when raised.
# BCRYPT_COST=12
# Public URL of the frontend (used for CORS allowlists, redirects, email links)
FRONTEND_URL=http://localhost:5173
# Comma-separated list of additional allowed browser origins for split frontend/backend deployments.
# CORS_ORIGIN=http://localhost:5173,https://app.example.com
# Production default is SameSite=None so Railway/Vercel-style separate frontend/backend origins can keep sessions.
# Set to strict only when frontend and backend are guaranteed same-site.
# AUTH_COOKIE_SAMESITE=none

# === AI ===
# OpenAI key (GPT-4o vision used for OCR). A key with sk-ant- prefix is auto-detected as Anthropic.
OPENAI_API_KEY=sk-your-openai-api-key
AI_MODEL=gpt-3.5-turbo
# Anthropic key (Claude vision used for OCR — takes precedence over OPENAI_API_KEY when set)
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# === Google Sheets Integration (Option 1: Service Account) ===
# GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
# GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# === Google Sheets Integration (Option 2: OAuth2) ===
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret
# GOOGLE_REFRESH_TOKEN=your-google-refresh-token

# === Email / SMTP (optional — features gracefully degrade if unset) ===
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-smtp-username
# SMTP_PASS=your-smtp-password
# SMTP_FROM=no-reply@muhasib.ai

# === Email / Resend (preferred over SMTP when both are set) ===
# RESEND_API_KEY=re_your-resend-api-key
# RESEND_FROM=no-reply@muhasib.ai

# === Logging ===
# fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# === Database / migrations ===
# AUTO_MIGRATE_ON_BOOT runs `runMigrations()` AND `ensureCriticalSchema()` on
# every app boot. Default is false. Keep false in production: migrations should
# run in the deploy release phase (`npm run db:migrate`), not on every replica's
# boot. Multi-replica boot races on DDL, and a failing migration on boot takes
# down ALL instances with no rollback story. Set to true for dev/test or
# single-instance setups where boot-time migration is convenient.
AUTO_MIGRATE_ON_BOOT=false
# Set to true/require for managed Postgres services that require TLS.
# Leave unset to let the connection URL's sslmode decide.
# DATABASE_SSL=true
# DATABASE_SSL_REJECT_UNAUTHORIZED=false

# === Client (Vite) ===
# Empty string means same-origin requests; set when frontend and backend run on different hosts.
# VITE_API_URL=http://localhost:5000

# === Deployment smoke checks ===
# Required for authenticated staging smoke. Never commit real values.
# STAGING_DATABASE_URL=postgresql://user:password@staging-host:5432/muhasib_staging
# SMOKE_BASE_URL=https://staging.example.com
# SMOKE_EMAIL=firm-smoke@example.com
# SMOKE_PASSWORD=replace-with-staging-smoke-password
# SMOKE_NAME=Staging Smoke
# SMOKE_FIRM_ROLE=firm_owner
# To use DATABASE_URL instead of STAGING_DATABASE_URL for credential bootstrap, opt in explicitly.
# SMOKE_ALLOW_DATABASE_URL=false
# Required only when SMOKE_FIRM_ROLE=firm_admin.
# SMOKE_COMPANY_IDS=company-uuid-1,company-uuid-2
# Optional: assert the deployed commit prefix in read-only production verification.
# SMOKE_EXPECTED_COMMIT=abcdef1
# Optional: enable write-path VAT workpaper smoke only in disposable staging data.
# SMOKE_WORKSPACE_MUTATIONS=false
