# ============================================
# Muhasib.ai Environment Configuration
# ============================================
# Copy this file to .env and fill in the values.

# === Required ===
DATABASE_URL=postgresql://user:password@host:5432/muhasib_db
SESSION_SECRET=your-session-secret-at-least-32-characters-long
JWT_SECRET=your-jwt-secret-at-least-32-characters-long-different-from-session

# === Server ===
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:5173

# === AI — set ONE of the following ===
# OpenAI key (GPT-4o vision used for OCR)
OPENAI_API_KEY=sk-your-openai-api-key
AI_MODEL=gpt-3.5-turbo
# Anthropic key (Claude vision used for OCR — takes precedence over OPENAI_API_KEY)
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# === Google Sheets Integration (Option 1: Service Account) ===
# GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
# GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# === Google Sheets Integration (Option 2: OAuth2) ===
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret
# GOOGLE_REFRESH_TOKEN=your-google-refresh-token

# === Logging ===
LOG_LEVEL=info

# === Database / migrations ===
# AUTO_MIGRATE_ON_BOOT runs `runMigrations()` on every app boot.
# Default is false. Keep false in production: migrations should run in the
# deploy release phase (`npm run db:migrate`), not on every replica's boot.
# Set to true for dev/test or single-instance setups where boot-time migration
# is convenient and the multi-replica DDL race isn't a concern.
AUTO_MIGRATE_ON_BOOT=true
