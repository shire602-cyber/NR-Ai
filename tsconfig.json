{
  "include": ["client/src/**/*", "shared/**/*", "server/**/*"],
  "exclude": [
    "node_modules",
    "build",
    "dist",
    "**/*.test.ts",
    "**/Temp/**",
    "**/bugbot-*/**",
    "**/.cursor/**",
    "server/routes/api-keys.routes.ts",
    "server/routes/billing.routes.ts",
    "server/routes/push.routes.ts",
    "server/routes/webhooks.routes.ts",
    "server/services/depreciation.service.ts",
    "server/services/invoice-payment.service.ts",
    "server/services/push-notification.service.ts",
    "server/services/stripe.service.ts",
    "server/services/webhook.service.ts",
    "client/src/hooks/useHealthCheck.ts",
    "client/src/lib/date-safe.ts",
    "client/src/lib/push.ts",
    "client/src/pages/DeveloperSettings.tsx",
    "client/src/pages/NotificationPreferences.tsx",
    "client/src/pages/Subscription.tsx"
  ],
  "compilerOptions": {
    "incremental": false,
    "noEmit": true,
    "target": "ES2022",
    "module": "ESNext",
    "strict": true,
    "lib": ["es2022", "dom", "dom.iterable"],
    "jsx": "preserve",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "types": ["node", "vite/client"],
    "paths": {
      "@/*": ["./client/src/*"],
      "@shared/*": ["./shared/*"]
    }
  },
  "ts-node": {
    "esm": true
  }
}
